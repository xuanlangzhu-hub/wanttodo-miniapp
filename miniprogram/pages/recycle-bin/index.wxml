<view class="page">
  <view class="header">
    <view>
      <view class="eyebrow">已移除</view>
      <view class="title">回收站</view>
    </view>
  </view>

  <view class="search-box">
    <input
      class="search-input"
      placeholder="搜索已移除卡片"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
    <button class="search-button" bindtap="onSearchConfirm">搜索</button>
  </view>

  <view class="summary">共 {{total}} 张</view>

  <view wx:if="{{!loading && cards.length === 0}}" class="empty">
    <view class="empty-title">回收站为空</view>
    <view class="empty-text">移入回收站的卡片会显示在这里。</view>
  </view>

  <view class="card-list">
    <view wx:for="{{cards}}" wx:key="id" class="card-item">
      <view class="card-top">
        <view class="card-title">{{item.title}}</view>
        <view class="status archived">已移除</view>
      </view>
      <view wx:if="{{item.summary}}" class="card-summary">{{item.summary}}</view>
      <view wx:elif="{{item.sourceText}}" class="card-summary">{{item.sourceText}}</view>
      <view class="card-footer">
        <text>{{item.deletedAtText}}</text>
        <view class="card-actions">
          <button class="text-button primary-link" catchtap="onRestoreTap" data-id="{{item.id}}">恢复</button>
          <button class="text-button danger-link" catchtap="onPermanentDeleteTap" data-id="{{item.id}}">彻底删除</button>
        </view>
      </view>
    </view>
  </view>
</view>
