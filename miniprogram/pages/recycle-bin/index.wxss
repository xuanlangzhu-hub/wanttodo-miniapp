@import "../index/index.wxss";

.search-box {
  align-items: center;
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 10rpx;
}

.search-input {
  color: #ffffff;
  flex: 1;
  font-size: 26rpx;
  height: 64rpx;
  padding: 0 14rpx;
}

.search-button {
  align-items: center;
  background: #353542;
  border-radius: 8rpx;
  color: #e0e0e6;
  display: flex;
  font-size: 24rpx;
  height: 64rpx;
  justify-content: center;
  margin: 0;
  padding: 0 24rpx;
}
