<view class="page">
  <view class="nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;">
    <view class="back-touch" bindtap="onBackTap">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">{{mode === 'edit' ? '编辑卡片' : '新建卡片'}}</view>
    <view class="nav-save {{saving ? 'disabled' : ''}}" bindtap="onSaveTap">
      {{saving ? '保存中' : '保存'}}
    </view>
  </view>

  <view class="form-wrap" style="padding-top: {{contentTop}}px;">
    <view class="form-card core-card">
      <view class="section-head">
        <view class="section-dot coral"></view>
        <view class="section-title">核心内容</view>
        <view class="section-subtitle">描述与内容是卡片的核心</view>
      </view>

      <view class="field">
        <view class="label-row">
          <text class="label">标题</text>
          <text class="counter">{{form.title.length}}/100</text>
        </view>
        <input
          class="input"
          maxlength="100"
          placeholder="写一个便于查找的标题"
          placeholder-class="placeholder"
          value="{{form.title}}"
          data-field="title"
          bindinput="onInput"
        />
      </view>

      <view class="field">
        <view class="label-row">
          <text class="label">内容</text>
          <text class="counter">{{form.sourceText.length}}/5000</text>
        </view>
        <textarea
          class="textarea large"
          maxlength="5000"
          placeholder="粘贴需要整理的材料"
          placeholder-class="placeholder"
          value="{{form.sourceText}}"
          data-field="sourceText"
          bindinput="onInput"
        ></textarea>
      </view>

      <view class="organize-panel">
        <view class="organize-copy">
          <view class="organize-title">智能整理</view>
          <view class="organize-subtitle">
            本卡剩余 {{organizeRemaining}} 次 · 今日剩余 {{dailyRemaining}} 次
          </view>
        </view>
        <view
          class="organize-button {{organizing ? 'disabled' : ''}} {{organizeRemaining <= 0 || dailyRemaining <= 0 ? 'exhausted' : ''}}"
          bindtap="onOrganizeTap"
        >
          {{organizing ? '整理中' : (organizeRemaining <= 0 || dailyRemaining <= 0 ? '次数已用完' : '提取摘要')}}
        </view>
      </view>

      <view class="field last">
        <view class="label-row">
          <text class="label">卡片摘要</text>
          <text class="counter">{{form.summary.length}}/1000</text>
        </view>
        <textarea
          class="textarea"
          maxlength="1000"
          placeholder="输入整理后的简洁摘要"
          placeholder-class="placeholder"
          value="{{form.summary}}"
          data-field="summary"
          bindinput="onInput"
        ></textarea>
      </view>
    </view>

    <view class="form-card">
      <view class="section-head">
        <view class="section-dot violet"></view>
        <view class="section-title">附加信息</view>
        <view class="section-subtitle">补充信息有助于管理卡片</view>
      </view>

      <view class="field">
        <view class="label">标签</view>
        <view class="preset-shell" wx:if="{{presetTagItems.length}}">
          <scroll-view class="preset-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
            <view class="preset-row">
              <view
                wx:for="{{presetTagItems}}"
                wx:key="name"
                class="preset-tag {{item.selected ? 'active' : ''}}"
                data-tag="{{item.name}}"
                bindtap="onPresetTagTap"
              >
                #{{item.name}}
              </view>
            </view>
          </scroll-view>
          <view class="tag-fade tag-fade-left"></view>
          <view class="tag-fade tag-fade-right"></view>
        </view>
        <input
          class="input"
          placeholder="选择标签或手动输入"
          placeholder-class="placeholder"
          value="{{form.tagsText}}"
          data-field="tagsText"
          bindinput="onInput"
        />
      </view>

      <view class="field">
        <view class="label">状态</view>
        <view class="status-row">
          <view
            wx:for="{{statusOptions}}"
            wx:key="value"
            class="status-option {{form.status === item.value ? 'active' : ''}}"
            data-status="{{item.value}}"
            bindtap="onStatusTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="field last">
        <view class="label">来源链接</view>
        <input
          class="input"
          placeholder="可选"
          placeholder-class="placeholder"
          value="{{form.sourceUrl}}"
          data-field="sourceUrl"
          bindinput="onInput"
        />
      </view>
    </view>
  </view>

  <view class="bottom-action">
    <button
      class="save-button"
      loading="{{saving}}"
      disabled="{{saving || (mode === 'create' && cardQuotaRemaining <= 0)}}"
      bindtap="onSaveTap"
    >
      {{mode === 'create' && cardQuotaRemaining <= 0 ? '已达100张上限' : '保存'}}
    </button>
  </view>
</view>
