page {
  min-height: 100vh;
  background: radial-gradient(circle at 50% 0%, #20202c 0%, #0e0e12 48%, #09090c 100%);
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 0 28rpx 190rpx;
}

.nav {
  align-items: center;
  box-sizing: content-box;
  display: flex;
  left: 0;
  padding-left: 26rpx;
  padding-right: 26rpx;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 40;
}

.nav::before {
  background: linear-gradient(180deg, rgba(14, 14, 18, 0.98), rgba(14, 14, 18, 0.72) 76%, rgba(14, 14, 18, 0));
  content: "";
  inset: 0;
  position: absolute;
}

.back-touch {
  align-items: center;
  display: flex;
  height: 72rpx;
  justify-content: center;
  position: relative;
  width: 72rpx;
  z-index: 1;
}

.back-icon {
  border-bottom: 4rpx solid #ffffff;
  border-left: 4rpx solid #ffffff;
  height: 22rpx;
  transform: rotate(45deg);
  width: 22rpx;
}

.nav-title {
  color: #ffffff;
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  margin-left: 8rpx;
  position: relative;
  text-align: center;
  z-index: 1;
}

.nav-save {
  color: #ff7966;
  font-size: 28rpx;
  font-weight: 700;
  position: relative;
  text-align: right;
  width: 80rpx;
  z-index: 1;
}

.form-wrap {
  box-sizing: border-box;
}

.form-card {
  background: linear-gradient(145deg, rgba(35, 35, 48, 0.9), rgba(16, 16, 24, 0.78));
  border: 1rpx solid rgba(131, 131, 156, 0.24);
  border-radius: 30rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 26rpx 62rpx rgba(0, 0, 0, 0.28);
  box-sizing: border-box;
  margin-bottom: 26rpx;
  overflow: hidden;
  padding: 30rpx;
  position: relative;
}

.core-card::before {
  background: radial-gradient(circle, rgba(255, 121, 102, 0.18), rgba(255, 121, 102, 0) 64%);
  content: "";
  height: 240rpx;
  left: -92rpx;
  position: absolute;
  top: -92rpx;
  width: 300rpx;
}

.section-head {
  align-items: center;
  display: flex;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.section-dot {
  border-radius: 50%;
  height: 14rpx;
  margin-right: 18rpx;
  width: 14rpx;
}

.section-dot.coral {
  background: #ff7966;
  box-shadow: 0 0 18rpx rgba(255, 121, 102, 0.62);
}

.section-dot.violet {
  background: #924eff;
  box-shadow: 0 0 18rpx rgba(146, 78, 255, 0.62);
}

.section-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #83839c;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.field {
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.field.last {
  margin-bottom: 0;
}

.label-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.label {
  color: #e0e0e6;
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.counter {
  color: #83839c;
  font-size: 23rpx;
  margin-bottom: 14rpx;
}

.input,
.textarea {
  background: rgba(14, 14, 18, 0.24);
  border: 1rpx solid rgba(131, 131, 156, 0.28);
  border-radius: 18rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 28rpx;
  width: 100%;
}

.placeholder {
  color: #666680;
}

.input {
  height: 82rpx;
  padding: 0 26rpx;
}

.textarea {
  line-height: 1.55;
  min-height: 154rpx;
  padding: 22rpx 26rpx;
}

.textarea.large {
  min-height: 286rpx;
}

.organize-panel {
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 121, 102, 0.12), rgba(146, 78, 255, 0.16));
  border: 1rpx solid rgba(146, 78, 255, 0.28);
  border-radius: 20rpx;
  box-sizing: border-box;
  display: flex;
  margin: -8rpx 0 30rpx;
  padding: 20rpx;
  position: relative;
  z-index: 1;
}

.organize-copy {
  flex: 1;
  min-width: 0;
}

.organize-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.organize-subtitle {
  color: #a2a2b5;
  font-size: 23rpx;
  line-height: 1.35;
  margin-top: 8rpx;
}

.organize-button {
  align-items: center;
  background: linear-gradient(100deg, #ff7966 0%, #bf44d9 58%, #7838ff 100%);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 28rpx rgba(146, 78, 255, 0.22);
  color: #ffffff;
  display: flex;
  flex-shrink: 0;
  font-size: 25rpx;
  font-weight: 800;
  height: 62rpx;
  justify-content: center;
  margin-left: 18rpx;
  min-width: 148rpx;
  padding: 0 20rpx;
  overflow: hidden;
  position: relative;
}

.organize-button.disabled {
  opacity: 0.82;
  padding-left: 48rpx;
}

.organize-button.exhausted {
  box-shadow: none;
  opacity: 0.48;
}

.organize-button.disabled::before {
  animation: organizeSpin 820ms linear infinite;
  border: 4rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 50%;
  border-top-color: #ffffff;
  box-sizing: border-box;
  content: "";
  height: 26rpx;
  left: 20rpx;
  pointer-events: none;
  position: absolute;
  width: 26rpx;
  z-index: 1;
}

.organize-button.disabled::after {
  animation: organizeFlow 1.8s ease-in-out infinite;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0));
  content: "";
  inset: 0;
  pointer-events: none;
  position: absolute;
  transform: translateX(-100%);
}

.preset-shell {
  margin-bottom: 14rpx;
  overflow: hidden;
  position: relative;
  width: 100%;
}

.preset-scroll {
  white-space: nowrap;
  width: 100%;
}

.preset-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 34rpx;
}

.tag-fade {
  bottom: 0;
  pointer-events: none;
  position: absolute;
  top: 0;
  width: 42rpx;
  z-index: 2;
}

.tag-fade-left {
  background: linear-gradient(90deg, rgba(27, 27, 38, 0.96), rgba(27, 27, 38, 0));
  left: 0;
}

.tag-fade-right {
  background: linear-gradient(270deg, rgba(27, 27, 38, 0.96), rgba(27, 27, 38, 0));
  right: 0;
}

.preset-tag {
  background: rgba(14, 14, 18, 0.18);
  border: 1rpx solid rgba(131, 131, 156, 0.24);
  border-radius: 999rpx;
  color: #a2a2b5;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.preset-tag.active {
  background: linear-gradient(135deg, rgba(255, 121, 102, 0.22), rgba(146, 78, 255, 0.26));
  border-color: rgba(255, 121, 102, 0.68);
  color: #ffffff;
  font-weight: 700;
}

.status-row {
  background: rgba(14, 14, 18, 0.2);
  border: 1rpx solid rgba(131, 131, 156, 0.28);
  border-radius: 18rpx;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  overflow: hidden;
  padding: 4rpx;
}

.status-option {
  align-items: center;
  border-radius: 14rpx;
  color: #83839c;
  display: flex;
  font-size: 27rpx;
  height: 72rpx;
  justify-content: center;
}

.status-option.active {
  background: linear-gradient(135deg, rgba(255, 121, 102, 0.28), rgba(146, 78, 255, 0.34));
  border: 1rpx solid rgba(255, 121, 102, 0.72);
  color: #ffffff;
  font-weight: 700;
}

.bottom-action {
  background: linear-gradient(180deg, rgba(9, 9, 12, 0), rgba(9, 9, 12, 0.82) 28%, rgba(9, 9, 12, 0.98));
  bottom: 0;
  box-sizing: border-box;
  left: 0;
  padding: 44rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 50;
}

.save-button {
  align-items: center;
  background: linear-gradient(100deg, #ff7966 0%, #bf44d9 58%, #7838ff 100%);
  border-radius: 22rpx;
  box-shadow: 0 18rpx 44rpx rgba(146, 78, 255, 0.28), 0 10rpx 28rpx rgba(255, 121, 102, 0.18);
  color: #ffffff;
  display: flex;
  font-size: 30rpx;
  font-weight: 800;
  height: 92rpx;
  justify-content: center;
  line-height: 1;
  margin: 0;
}

.save-button::after {
  border: 0;
}

.nav-save.disabled {
  opacity: 0.5;
}

.save-button[disabled] {
  background: #353545;
  box-shadow: none;
  color: #9292a6;
  opacity: 1;
}

@keyframes organizeSpin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes organizeFlow {
  0% {
    transform: translateX(-100%);
  }

  60%,
  100% {
    transform: translateX(100%);
  }
}
