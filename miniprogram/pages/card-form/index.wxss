page {
  min-height: 100vh;
  background: #0e0e12;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx 72rpx;
}

.field {
  margin-bottom: 26rpx;
}

.label {
  color: #e0e0e6;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 28rpx;
  width: 100%;
}

.input {
  height: 80rpx;
  padding: 0 22rpx;
}

.textarea {
  line-height: 1.45;
  min-height: 160rpx;
  padding: 20rpx 22rpx;
}

.textarea.large {
  min-height: 260rpx;
}

.status-row {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  display: grid;
  gap: 6rpx;
  grid-template-columns: repeat(3, 1fr);
  padding: 6rpx;
}

.status-option {
  border-radius: 6rpx;
  color: #83839c;
  font-size: 26rpx;
  line-height: 64rpx;
  text-align: center;
}

.status-option.active {
  background: #353542;
  color: #ffffff;
  font-weight: 600;
}

.save-button {
  align-items: center;
  background: linear-gradient(180deg, #ffa699 0%, #ff7966 100%);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 36rpx rgba(255, 121, 102, 0.3);
  color: #ffffff;
  display: flex;
  font-size: 30rpx;
  height: 88rpx;
  justify-content: center;
  margin: 34rpx 0 0;
}
