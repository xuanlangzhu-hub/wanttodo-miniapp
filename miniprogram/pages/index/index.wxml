<view class="page">
  <view class="header">
    <view>
      <view class="eyebrow">WantTodo</view>
      <view class="title">今天要做什么？</view>
    </view>
    <button wx:if="{{!loggedIn}}" class="login-button" bindtap="onLoginTap">登录</button>
    <view wx:else class="avatar">
      <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text wx:else>{{avatarText}}</text>
    </view>
  </view>

  <view class="composer">
    <input
      class="todo-input"
      placeholder="添加一个待办"
      value="{{newTitle}}"
      confirm-type="done"
      bindinput="onInputTitle"
      bindconfirm="onAddTodo"
    />
    <button class="add-button" bindtap="onAddTodo">添加</button>
  </view>

  <view class="tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="value"
      class="tab {{status === item.value ? 'active' : ''}}"
      data-status="{{item.value}}"
      bindtap="onTabTap"
    >
      {{item.label}}
    </view>
  </view>

  <view class="summary">共 {{total}} 条</view>

  <view wx:if="{{!loading && todos.length === 0}}" class="empty">
    <view class="empty-title">还没有待办</view>
    <view class="empty-text">先添加一条，后端连通后会显示在这里。</view>
  </view>

  <view class="todo-list">
    <view wx:for="{{todos}}" wx:key="id" class="todo-item {{item.completed ? 'done' : ''}}">
      <view
        class="check"
        data-id="{{item.id}}"
        data-completed="{{item.completed}}"
        bindtap="onToggleTodo"
      >
        <text wx:if="{{item.completed}}">✓</text>
      </view>
      <view class="todo-main">
        <view class="todo-title">{{item.title}}</view>
        <view wx:if="{{item.description}}" class="todo-desc">{{item.description}}</view>
        <view class="todo-meta">
          <text>优先级 {{item.priority}}</text>
          <text wx:if="{{item.dueDate}}">截止 {{item.dueDate}}</text>
        </view>
      </view>
      <button class="delete-button" data-id="{{item.id}}" bindtap="onDeleteTodo">删除</button>
    </view>
  </view>
</view>
