<view class="page">
  <view class="search-shell">
    <view class="search-icon"></view>
    <input
      class="search-input"
      placeholder="搜索卡片、标签或材料"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
  </view>

  <view class="hero-card">
    <view class="hero-copy">
      <view class="hero-kicker">学习记录</view>
      <view class="hero-title">AI知识卡片</view>
      <view class="hero-subtitle">整理概念、提示词、工具，构建你的专属知识库</view>
      <view class="hero-button {{cardLimitReached ? 'disabled' : ''}}" bindtap="onHeroActionTap">
        {{!loggedIn ? '登录开始' : (cardLimitReached ? '已达100张上限' : '开始整理')}}<text wx:if="{{!cardLimitReached}}">→</text>
      </view>
    </view>
    <view class="hero-art" aria-hidden="true">
      <view class="orbit orbit-one"></view>
      <view class="orbit orbit-two"></view>
      <view class="ai-panel">
        <view class="ai-chip">AI</view>
        <view class="ai-line wide"></view>
        <view class="ai-line"></view>
      </view>
      <view class="floating-node node-chat"></view>
      <view class="floating-node node-code"></view>
      <view class="floating-cube"></view>
    </view>
  </view>

  <view class="overview-grid">
    <view class="overview-card">
      <view class="overview-icon stack-icon">
        <view class="stack-back"></view>
        <view class="stack-front"></view>
        <view class="stack-bar"></view>
      </view>
      <view class="overview-copy">
        <view class="overview-label">总卡片数</view>
        <view class="overview-value">{{displayTotalCount}}<text>张</text></view>
      </view>
    </view>

    <view class="overview-card">
      <view class="overview-icon ring-icon plus-ring">
        <view class="ring-core">+</view>
      </view>
      <view class="overview-copy">
        <view class="overview-label">待整理</view>
        <view class="overview-value">{{displayTodoCount}}<text>张</text></view>
      </view>
    </view>

    <view class="overview-card">
      <view class="overview-icon ring-icon progress-ring">
        <view class="ring-core percent-core"></view>
      </view>
      <view class="overview-copy">
        <view class="overview-label">已整理</view>
        <view class="overview-value">{{displayDoneRate}}<text>%</text></view>
      </view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">最近整理卡片</view>
    <view class="section-link" bindtap="onViewAllTap">查看全部</view>
  </view>

  <view wx:if="{{!loggedIn}}" class="empty glass-empty">
    <view class="empty-title">登录后开始整理</view>
    <view class="empty-text">把材料整理成自己的知识卡片。</view>
  </view>

  <view wx:elif="{{!loading && recentCards.length === 0}}" class="empty glass-empty">
    <view class="empty-title">还没有整理记录</view>
    <view class="empty-text">新建一张卡片后，会显示在这里。</view>
  </view>

  <view class="recent-list">
    <view wx:for="{{recentCards}}" wx:key="id" class="recent-card" data-id="{{item.id}}" bindtap="onCardTap">
      <view class="recent-icon">
        <view class="recent-icon-dot"></view>
      </view>
      <view class="recent-main">
        <view class="recent-title">{{item.title}}</view>
        <view wx:if="{{item.summary}}" class="recent-summary">{{item.summary}}</view>
        <view wx:elif="{{item.sourceText}}" class="recent-summary">{{item.sourceText}}</view>
        <view class="tag-row" wx:if="{{item.tags && item.tags.length}}">
          <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
        </view>
      </view>
      <view class="status {{item.status}}">{{item.statusText}}</view>
    </view>
  </view>

  <bottom-nav active="home"></bottom-nav>
</view>
