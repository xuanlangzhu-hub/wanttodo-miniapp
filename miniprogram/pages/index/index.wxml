<view class="page">
  <view class="header">
    <view>
      <view class="eyebrow">学习记录</view>
      <view class="title">我的工作台</view>
    </view>
    <button wx:if="{{!loggedIn}}" class="login-button" bindtap="onLoginTap">登录</button>
    <view wx:else class="avatar">
      <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text wx:else>{{avatarText}}</text>
    </view>
  </view>

  <view class="quick-panel">
    <button class="primary-action" bindtap="onCreateTap">新建卡片</button>
    <view class="metric">
      <view class="metric-value">{{pendingCards.length}}</view>
      <view class="metric-label">待整理</view>
    </view>
    <view class="metric">
      <view class="metric-value">{{recentCards.length}}</view>
      <view class="metric-label">最近整理</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">待整理</view>
    <view wx:if="{{pendingCards.length === 0}}" class="mini-empty">暂无待整理卡片</view>
    <view wx:else class="compact-list">
      <view
        wx:for="{{pendingCards}}"
        wx:key="id"
        class="compact-item"
        data-id="{{item.id}}"
        bindtap="onCardTap"
      >
        <text>{{item.title}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">内容池</view>
    <view class="tabs">
      <view
        wx:for="{{statusTabs}}"
        wx:key="value"
        class="tab {{status === item.value ? 'active' : ''}}"
        data-status="{{item.value}}"
        bindtap="onTabTap"
      >
        {{item.label}}
      </view>
    </view>
    <view class="summary">共 {{total}} 张</view>
  </view>

  <view wx:if="{{!loggedIn}}" class="empty">
    <view class="empty-title">登录后开始整理</view>
    <view class="empty-text">把材料整理成自己的知识卡片。</view>
  </view>

  <view wx:elif="{{!loading && cards.length === 0}}" class="empty">
    <view class="empty-title">还没有卡片</view>
    <view class="empty-text">先新建一张，之后会显示在内容池。</view>
  </view>

  <view class="card-list">
    <view wx:for="{{cards}}" wx:key="id" class="card-item" data-id="{{item.id}}" bindtap="onCardTap">
      <view class="card-top">
        <view class="card-title">{{item.title}}</view>
        <view class="status {{item.status}}">{{item.statusText}}</view>
      </view>
      <view wx:if="{{item.summary}}" class="card-summary">{{item.summary}}</view>
      <view wx:elif="{{item.sourceText}}" class="card-summary">{{item.sourceText}}</view>
      <view class="tag-row" wx:if="{{item.tags && item.tags.length}}">
        <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="card-footer">
        <text>{{item.updatedAtText}}</text>
        <button
          wx:if="{{item.status !== 'archived'}}"
          class="text-button"
          catchtap="onArchiveTap"
          data-id="{{item.id}}"
        >
          归档
        </button>
      </view>
    </view>
  </view>
</view>
