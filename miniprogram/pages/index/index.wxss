page {
  min-height: 100vh;
  background: #0e0e12;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 44rpx 32rpx 190rpx;
}

.header,
.quick-panel,
.card-top,
.card-footer {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: #83839c;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 600;
}

.login-button,
.primary-action,
.text-button {
  align-items: center;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  margin: 0;
}

.login-button {
  background: linear-gradient(180deg, #ffa699 0%, #ff7966 100%);
  box-shadow: 0 12rpx 28rpx rgba(255, 121, 102, 0.32);
  color: #ffffff;
  font-size: 26rpx;
  height: 64rpx;
  padding: 0 28rpx;
}

.avatar {
  align-items: center;
  background: #353542;
  border: 1rpx solid #4e4e61;
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  font-size: 28rpx;
  font-weight: 600;
  height: 72rpx;
  justify-content: center;
  overflow: hidden;
  width: 72rpx;
}

.avatar image {
  height: 100%;
  width: 100%;
}

.quick-panel {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  gap: 18rpx;
  padding: 18rpx;
}

.primary-action {
  background: linear-gradient(180deg, #ffa699 0%, #ff7966 100%);
  box-shadow: 0 12rpx 28rpx rgba(255, 121, 102, 0.28);
  color: #ffffff;
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.metric {
  min-width: 112rpx;
  text-align: center;
}

.metric-value {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
}

.metric-label {
  color: #a2a2b5;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.section {
  margin-top: 32rpx;
}

.section-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.mini-empty {
  background: #1c1c23;
  border: 1rpx dashed #4e4e61;
  border-radius: 8rpx;
  color: #a2a2b5;
  font-size: 26rpx;
  padding: 24rpx;
  text-align: center;
}

.compact-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.compact-item {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  color: #e0e0e6;
  font-size: 28rpx;
  padding: 22rpx 24rpx;
}

.tabs {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  display: grid;
  gap: 6rpx;
  grid-template-columns: repeat(4, 1fr);
  padding: 6rpx;
}

.tab {
  border-radius: 6rpx;
  color: #83839c;
  font-size: 24rpx;
  line-height: 56rpx;
  text-align: center;
}

.tab.active {
  background: #353542;
  color: #ffffff;
  font-weight: 600;
}

.summary {
  color: #83839c;
  font-size: 24rpx;
  margin-top: 16rpx;
}

.empty {
  align-items: center;
  background: #1c1c23;
  border: 1rpx dashed #4e4e61;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  margin-top: 24rpx;
  padding: 64rpx 32rpx;
}

.empty-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.empty-text {
  color: #a2a2b5;
  font-size: 26rpx;
  margin-top: 12rpx;
  text-align: center;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.card-item {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  box-sizing: border-box;
  padding: 24rpx;
}

.card-title {
  color: #ffffff;
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.status {
  border-radius: 999rpx;
  color: #c1c1cd;
  flex-shrink: 0;
  font-size: 22rpx;
  margin-left: 16rpx;
  padding: 6rpx 14rpx;
}

.status.todo {
  background: rgba(146, 78, 255, 0.18);
  color: #c9a7ff;
}

.status.done {
  background: rgba(46, 235, 210, 0.14);
  color: #63f0df;
}

.status.archived {
  background: #353542;
  color: #a2a2b5;
}

.card-summary {
  color: #c1c1cd;
  font-size: 26rpx;
  line-height: 1.45;
  margin-top: 14rpx;
  word-break: break-all;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.tag {
  background: rgba(94, 0, 245, 0.22);
  border-radius: 6rpx;
  color: #c9a7ff;
  font-size: 22rpx;
  padding: 6rpx 10rpx;
}

.card-footer {
  align-items: center;
  color: #83839c;
  font-size: 22rpx;
  margin-top: 18rpx;
}

.card-actions {
  display: flex;
  flex-shrink: 0;
  gap: 10rpx;
}

.text-button {
  background: #353542;
  color: #e0e0e6;
  font-size: 24rpx;
  height: 48rpx;
  padding: 0 18rpx;
}

.text-button.primary-link {
  background: rgba(255, 121, 102, 0.18);
  color: #ff9a86;
}

.text-button.danger-link {
  background: rgba(255, 121, 102, 0.12);
  color: #ff7966;
}
