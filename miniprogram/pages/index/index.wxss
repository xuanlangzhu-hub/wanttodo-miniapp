page {
  min-height: 100vh;
  background: #f5f7fb;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 44rpx 32rpx 72rpx;
}

.header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.eyebrow {
  color: #5d6678;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.title {
  color: #172033;
  font-size: 44rpx;
  font-weight: 600;
}

.login-button,
.add-button,
.delete-button {
  align-items: center;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  margin: 0;
}

.login-button {
  background: #172033;
  color: #ffffff;
  font-size: 26rpx;
  height: 64rpx;
  padding: 0 28rpx;
}

.avatar {
  align-items: center;
  background: #dbe4f0;
  border-radius: 50%;
  color: #172033;
  display: flex;
  font-size: 28rpx;
  font-weight: 600;
  height: 72rpx;
  justify-content: center;
  overflow: hidden;
  width: 72rpx;
}

.avatar image {
  height: 100%;
  width: 100%;
}

.composer {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 8rpx;
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
}

.todo-input {
  color: #172033;
  flex: 1;
  font-size: 30rpx;
  min-height: 64rpx;
}

.add-button {
  background: #2f6fed;
  color: #ffffff;
  font-size: 28rpx;
  height: 64rpx;
  padding: 0 28rpx;
}

.tabs {
  background: #e9eef6;
  border-radius: 8rpx;
  display: grid;
  gap: 6rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 28rpx;
  padding: 6rpx;
}

.tab {
  border-radius: 6rpx;
  color: #5d6678;
  font-size: 26rpx;
  line-height: 56rpx;
  text-align: center;
}

.tab.active {
  background: #ffffff;
  color: #172033;
  font-weight: 600;
}

.summary {
  color: #687387;
  font-size: 24rpx;
  margin: 24rpx 0 16rpx;
}

.empty {
  align-items: center;
  background: #ffffff;
  border: 1rpx dashed #cfd8e6;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  margin-top: 24rpx;
  padding: 64rpx 32rpx;
}

.empty-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 600;
}

.empty-text {
  color: #687387;
  font-size: 26rpx;
  margin-top: 12rpx;
  text-align: center;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.todo-item {
  align-items: flex-start;
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
}

.check {
  align-items: center;
  border: 2rpx solid #b7c2d2;
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  flex-shrink: 0;
  font-size: 28rpx;
  height: 40rpx;
  justify-content: center;
  margin-top: 4rpx;
  width: 40rpx;
}

.todo-item.done .check {
  background: #1f9d63;
  border-color: #1f9d63;
}

.todo-main {
  flex: 1;
  min-width: 0;
}

.todo-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.todo-item.done .todo-title {
  color: #8a94a6;
  text-decoration: line-through;
}

.todo-desc {
  color: #5d6678;
  font-size: 26rpx;
  line-height: 1.45;
  margin-top: 8rpx;
  word-break: break-all;
}

.todo-meta {
  color: #8a94a6;
  display: flex;
  flex-direction: column;
  font-size: 22rpx;
  gap: 4rpx;
  margin-top: 12rpx;
}

.delete-button {
  background: #f3f5f8;
  color: #5d6678;
  flex-shrink: 0;
  font-size: 24rpx;
  height: 52rpx;
  padding: 0 18rpx;
}
