<view class="page">
  <view class="search-shell">
    <view class="search-icon"></view>
    <input
      class="search-input"
      placeholder="搜索标签或知识方向"
      placeholder-class="placeholder"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
  </view>

  <view class="hero-card">
    <view class="hero-copy">
      <view class="hero-title">知识体系</view>
      <view class="hero-subtitle">按标签和整理状态找回你的 AI 学习内容</view>
      <view class="hero-stats">
        <view>
          <text>{{topTags.length}}</text>
          <view>个标签</view>
        </view>
        <view>
          <text>{{totalCards}}</text>
          <view>张卡片</view>
        </view>
        <view>
          <text>{{donePercent}}%</text>
          <view>已整理</view>
        </view>
      </view>
    </view>
    <view class="hero-art">
      <view class="folder-icon">
        <view class="folder-tab"></view>
      </view>
      <view class="orbit orbit-one"></view>
      <view class="orbit orbit-two"></view>
      <view class="mini-node node-tag"></view>
      <view class="mini-node node-grid"></view>
      <view class="mini-node node-link"></view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">标签目录</view>
    <view class="section-link" bindtap="onManageHintTap">按数量排序</view>
  </view>

  <view wx:if="{{!loading && filteredTags.length === 0}}" class="empty-card">
    <view class="empty-title">{{loggedIn ? '暂无标签' : '登录后查看标签'}}</view>
    <view class="empty-text">{{loggedIn ? '保存卡片时添加标签，这里会自动形成目录。' : '登录后会显示你的知识体系。'}}</view>
  </view>

  <view class="tag-grid" wx:else>
    <view
      wx:for="{{filteredTags}}"
      wx:key="name"
      class="tag-card"
      data-tag="{{item.name}}"
      bindtap="onTagTap"
    >
      <view class="tag-icon">{{item.initial}}</view>
      <view class="tag-main">
        <view class="tag-name">{{item.name}}</view>
        <view class="tag-count">{{item.count}} 张卡片</view>
      </view>
      <view class="tag-percent">{{item.percent}}%</view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{item.percent}}%;"></view>
      </view>
    </view>
  </view>

  <view class="section-head compact">
    <view class="section-title">整理状态</view>
  </view>

  <view class="status-card">
    <view
      wx:for="{{statusRows}}"
      wx:key="value"
      class="status-row"
      data-status="{{item.value}}"
      bindtap="onStatusTap"
    >
      <view class="status-left">
        <view class="status-dot {{item.value}}"></view>
        <text>{{item.label}}</text>
      </view>
      <view class="status-bar">
        <view class="status-fill" style="width: {{item.percent}}%;"></view>
      </view>
      <view class="status-count">{{item.count}}</view>
    </view>
  </view>

  <bottom-nav active="pending"></bottom-nav>
</view>
