<view class="page">
  <view class="header">
    <view class="eyebrow">继续整理</view>
    <view class="title">待整理</view>
  </view>

  <view class="summary">共 {{total}} 张</view>

  <view wx:if="{{!loading && cards.length === 0}}" class="empty">
    <view class="empty-title">暂无待整理卡片</view>
    <view class="empty-text">点击底部加号添加新的学习记录。</view>
  </view>

  <view class="card-list">
    <view wx:for="{{cards}}" wx:key="id" class="card-item" data-id="{{item.id}}" bindtap="onCardTap">
      <view class="card-top">
        <view class="card-title">{{item.title}}</view>
        <view class="status todo">待整理</view>
      </view>
      <view wx:if="{{item.summary}}" class="card-summary">{{item.summary}}</view>
      <view wx:elif="{{item.sourceText}}" class="card-summary">{{item.sourceText}}</view>
      <view class="card-footer">
        <text>{{item.updatedAtText}}</text>
        <view class="card-actions">
          <button class="text-button primary-link" catchtap="onOrganizeTap" data-id="{{item.id}}">去整理</button>
          <button class="text-button" catchtap="onArchiveTap" data-id="{{item.id}}">归档</button>
        </view>
      </view>
    </view>
  </view>

  <bottom-nav active="pending"></bottom-nav>
</view>
