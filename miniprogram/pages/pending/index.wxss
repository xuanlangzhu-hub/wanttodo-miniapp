page {
  min-height: 100vh;
  background: radial-gradient(circle at 50% 0%, #20202c 0%, #0e0e12 48%, #09090c 100%);
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 106rpx 32rpx 190rpx;
}

.search-shell {
  align-items: center;
  background: rgba(28, 28, 35, 0.74);
  border: 1rpx solid rgba(131, 131, 156, 0.28);
  border-radius: 42rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 18rpx 42rpx rgba(0, 0, 0, 0.22);
  display: flex;
  height: 84rpx;
  margin-bottom: 28rpx;
  padding: 0 30rpx;
}

.search-icon {
  border: 4rpx solid #a2a2b5;
  border-radius: 50%;
  box-sizing: border-box;
  height: 32rpx;
  margin-right: 18rpx;
  position: relative;
  width: 32rpx;
}

.search-icon::after {
  background: #a2a2b5;
  border-radius: 999rpx;
  bottom: -8rpx;
  content: "";
  height: 4rpx;
  position: absolute;
  right: -10rpx;
  transform: rotate(45deg);
  width: 18rpx;
}

.search-input {
  color: #ffffff;
  flex: 1;
  font-size: 28rpx;
  height: 84rpx;
}

.placeholder {
  color: #666680;
}

.hero-card,
.tag-card,
.status-card,
.empty-card {
  background: linear-gradient(145deg, rgba(35, 35, 48, 0.9), rgba(16, 16, 24, 0.78));
  border: 1rpx solid rgba(131, 131, 156, 0.24);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 26rpx 62rpx rgba(0, 0, 0, 0.28);
}

.hero-card {
  border-radius: 30rpx;
  box-sizing: border-box;
  min-height: 260rpx;
  overflow: hidden;
  padding: 36rpx 34rpx;
  position: relative;
}

.hero-copy {
  position: relative;
  z-index: 2;
}

.hero-title {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
}

.hero-subtitle {
  color: #a2a2b5;
  font-size: 27rpx;
  line-height: 1.5;
  margin-top: 16rpx;
  max-width: 360rpx;
}

.hero-stats {
  display: flex;
  gap: 42rpx;
  margin-top: 32rpx;
}

.hero-stats text {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
}

.hero-stats view view {
  color: #a2a2b5;
  font-size: 23rpx;
  margin-top: 6rpx;
}

.hero-art {
  height: 220rpx;
  position: absolute;
  right: 8rpx;
  top: 22rpx;
  width: 278rpx;
}

.folder-icon {
  background: linear-gradient(145deg, rgba(255, 121, 102, 0.96), rgba(94, 0, 245, 0.88));
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 20rpx;
  box-shadow: 0 0 42rpx rgba(146, 78, 255, 0.28);
  height: 110rpx;
  position: absolute;
  right: 72rpx;
  top: 42rpx;
  width: 140rpx;
}

.folder-tab {
  background: rgba(255, 255, 255, 0.18);
  border-radius: 12rpx 12rpx 0 0;
  height: 26rpx;
  left: 18rpx;
  position: absolute;
  top: -12rpx;
  width: 58rpx;
}

.orbit {
  border: 2rpx solid rgba(146, 78, 255, 0.32);
  border-left-color: rgba(255, 121, 102, 0.7);
  border-radius: 50%;
  position: absolute;
}

.orbit-one {
  height: 140rpx;
  right: 26rpx;
  top: 36rpx;
  transform: rotate(-15deg);
  width: 230rpx;
}

.orbit-two {
  border-color: rgba(255, 121, 102, 0.26);
  border-right-color: rgba(146, 78, 255, 0.78);
  height: 104rpx;
  right: 42rpx;
  top: 58rpx;
  transform: rotate(16deg);
  width: 190rpx;
}

.mini-node {
  background: linear-gradient(145deg, rgba(53, 53, 66, 0.96), rgba(26, 26, 38, 0.96));
  border: 1rpx solid rgba(146, 78, 255, 0.5);
  border-radius: 18rpx;
  box-shadow: 0 0 28rpx rgba(146, 78, 255, 0.22);
  height: 58rpx;
  position: absolute;
  width: 58rpx;
}

.node-tag {
  left: 20rpx;
  top: 118rpx;
}

.node-grid {
  right: 18rpx;
  top: 34rpx;
}

.node-link {
  bottom: 8rpx;
  right: 62rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 38rpx 2rpx 20rpx;
}

.section-head.compact {
  margin-top: 34rpx;
}

.section-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.section-link {
  color: #83839c;
  font-size: 24rpx;
}

.tag-grid {
  display: grid;
  gap: 18rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.tag-card {
  border-radius: 24rpx;
  box-sizing: border-box;
  min-height: 174rpx;
  overflow: hidden;
  padding: 22rpx;
  position: relative;
}

.tag-icon {
  align-items: center;
  background: linear-gradient(145deg, rgba(94, 0, 245, 0.42), rgba(255, 121, 102, 0.2));
  border: 1rpx solid rgba(146, 78, 255, 0.42);
  border-radius: 18rpx;
  color: #ffffff;
  display: flex;
  font-size: 30rpx;
  font-weight: 800;
  height: 70rpx;
  justify-content: center;
  margin-bottom: 18rpx;
  width: 70rpx;
}

.tag-name {
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-count {
  color: #a2a2b5;
  font-size: 23rpx;
  margin-top: 6rpx;
}

.tag-percent {
  color: #c1c1cd;
  font-size: 26rpx;
  position: absolute;
  right: 22rpx;
  top: 32rpx;
}

.progress-track,
.status-bar {
  background: rgba(53, 53, 66, 0.66);
  border-radius: 999rpx;
  height: 8rpx;
  overflow: hidden;
}

.progress-track {
  bottom: 22rpx;
  left: 22rpx;
  position: absolute;
  right: 22rpx;
}

.progress-fill,
.status-fill {
  background: linear-gradient(90deg, #ff7966, #bf44d9, #7838ff);
  border-radius: 999rpx;
  height: 100%;
}

.status-card {
  border-radius: 24rpx;
  box-sizing: border-box;
  padding: 18rpx 24rpx;
}

.status-row {
  align-items: center;
  display: grid;
  gap: 18rpx;
  grid-template-columns: 160rpx minmax(0, 1fr) 58rpx;
  min-height: 70rpx;
}

.status-left {
  align-items: center;
  color: #c1c1cd;
  display: flex;
  font-size: 27rpx;
}

.status-dot {
  border-radius: 50%;
  height: 18rpx;
  margin-right: 14rpx;
  width: 18rpx;
}

.status-dot.done {
  background: #46d5c4;
}

.status-dot.todo {
  background: #924eff;
}

.status-dot.archived {
  background: #83839c;
}

.status-count {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  text-align: right;
}

.empty-card {
  align-items: center;
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 56rpx 32rpx;
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-text {
  color: #a2a2b5;
  font-size: 25rpx;
  line-height: 1.45;
  margin-top: 12rpx;
  text-align: center;
}
