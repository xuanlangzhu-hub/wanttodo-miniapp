<view class="page">
  <view class="profile-head">
    <view class="profile-avatar">
      <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text wx:else>{{avatarText}}</text>
    </view>
    <view>
      <view class="profile-name">{{userInfo.nickname || '未登录'}}</view>
      <view class="profile-subtitle">学习记录</view>
    </view>
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-value">{{total}}</view>
      <view class="stat-label">全部卡片</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{pending}}</view>
      <view class="stat-label">待整理</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{done}}</view>
      <view class="stat-label">已整理</view>
    </view>
  </view>

  <view class="settings">
    <view class="setting-row">
      <text>当前版本</text>
      <text>v1 知识卡片</text>
    </view>
    <button class="logout-button" bindtap="onLogoutTap">退出登录</button>
  </view>

  <bottom-nav active="me"></bottom-nav>
</view>
