<view class="page">
  <view class="profile-hero">
    <view class="avatar-wrap">
      <view class="profile-avatar">
        <image wx:if="{{userInfo && userInfo.avatarUrl}}" src="{{userInfo && userInfo.avatarUrl}}" mode="aspectFill"></image>
        <text wx:else>{{avatarText}}</text>
      </view>
    </view>
    <view class="profile-name">{{(userInfo && userInfo.nickname) || '未登录'}}</view>
    <view class="profile-subtitle">构建自己的 AI 知识体系</view>
    <view class="study-badge">
      <view class="badge-dot"></view>
      <text>{{loggedIn ? '学习记录已同步' : '登录后同步学习记录'}}</text>
    </view>
  </view>

  <view class="summary-card">
    <view class="summary-item">
      <view class="summary-icon card-icon"></view>
      <view>
        <view class="summary-value">{{total}}</view>
        <view class="summary-label">卡片</view>
      </view>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <view class="summary-icon grid-icon">
        <view></view>
        <view></view>
        <view></view>
        <view></view>
      </view>
      <view>
        <view class="summary-value">{{tagCount}}</view>
        <view class="summary-label">标签</view>
      </view>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <view class="summary-icon check-icon"></view>
      <view>
        <view class="summary-value">{{done}}</view>
        <view class="summary-label">已整理</view>
      </view>
    </view>
  </view>

  <view class="status-card">
    <view class="card-title">学习状态</view>
    <view class="status-grid">
      <view class="status-item">
        <view class="status-number">{{pending}}</view>
        <view class="status-label">待整理</view>
      </view>
      <view class="status-item">
        <view class="status-number">{{done}}</view>
        <view class="status-label">已整理</view>
      </view>
      <view class="status-item">
        <view class="status-number">{{archived}}</view>
        <view class="status-label">已归档</view>
      </view>
    </view>
    <view class="quota-list">
      <view class="quota-row">
        <text>累计创建额度</text>
        <text>{{totalCardsCreated}} / {{cardLimit}}</text>
      </view>
      <view class="quota-row">
        <text>今日智能整理剩余</text>
        <text>{{dailyAiRemaining}} / {{dailyAiLimit}}</text>
      </view>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-row" bindtap="onStudyRecordTap">
      <view class="menu-icon record-icon"></view>
      <text>学习记录</text>
      <view class="menu-meta">{{done}} 张已整理</view>
      <view class="chevron"></view>
    </view>
    <view class="menu-row" bindtap="onOverviewTap">
      <view class="menu-icon overview-icon"></view>
      <text>数据概览</text>
      <view class="menu-meta">{{total}} 张卡片</view>
      <view class="chevron"></view>
    </view>
    <view class="menu-row" bindtap="onRecycleTap">
      <view class="menu-icon recycle-icon"></view>
      <text>回收站</text>
      <view class="menu-meta">{{deleted}} 张</view>
      <view class="chevron"></view>
    </view>
  </view>

  <view class="menu-card quiet">
    <view class="menu-row" bindtap="onPrivacyTap">
      <view class="menu-icon privacy-icon"></view>
      <text>隐私政策</text>
      <view class="menu-meta">个人信息说明</view>
      <view class="chevron"></view>
    </view>
    <view class="menu-row" bindtap="onAboutTap">
      <view class="menu-icon info-icon"></view>
      <text>关于应用</text>
      <view class="menu-meta">v2 知识卡片</view>
      <view class="chevron"></view>
    </view>
  </view>

  <button class="auth-button" bindtap="onAuthButtonTap">{{loggedIn ? '退出登录' : '登录'}}</button>

  <bottom-nav active="me"></bottom-nav>
</view>
