@import "../index/index.wxss";

.profile-head {
  align-items: center;
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  display: flex;
  gap: 22rpx;
  padding: 28rpx;
}

.profile-avatar {
  align-items: center;
  background: #353542;
  border: 1rpx solid #4e4e61;
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 88rpx;
  justify-content: center;
  overflow: hidden;
  width: 88rpx;
}

.profile-avatar image {
  height: 100%;
  width: 100%;
}

.profile-name {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
}

.profile-subtitle {
  color: #a2a2b5;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.stats-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 28rpx;
}

.stat-card {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  padding: 24rpx 12rpx;
  text-align: center;
}

.stat-value {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 600;
}

.stat-label {
  color: #a2a2b5;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.settings {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  margin-top: 28rpx;
  padding: 24rpx;
}

.setting-row {
  color: #c1c1cd;
  display: flex;
  font-size: 26rpx;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.logout-button {
  background: rgba(255, 121, 102, 0.12);
  border-radius: 8rpx;
  color: #ff7966;
  font-size: 28rpx;
  height: 76rpx;
  margin: 0;
}
