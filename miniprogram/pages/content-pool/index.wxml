<view class="page">
  <view class="search-shell">
    <view class="search-icon"></view>
    <input
      class="search-input"
      placeholder="搜索卡片标题、标签或内容"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
  </view>

  <view class="suggest-panel" wx:if="{{showSuggestions}}">
    <view class="suggest-row" wx:if="{{suggestions.keywords.length}}">
      <view class="suggest-label">关键词</view>
      <view class="suggest-chips">
        <view
          wx:for="{{suggestions.keywords}}"
          wx:key="*this"
          class="suggest-chip"
          data-keyword="{{item}}"
          catchtap="onSuggestionKeywordTap"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="suggest-row" wx:if="{{suggestions.tags.length}}">
      <view class="suggest-label">标签</view>
      <view class="suggest-chips">
        <view
          wx:for="{{suggestions.tags}}"
          wx:key="*this"
          class="suggest-chip tag-suggest"
          data-tag="{{item}}"
          catchtap="onSuggestionTagTap"
        >
          #{{item}}
        </view>
      </view>
    </view>

    <view class="suggest-row" wx:if="{{suggestions.cards.length}}">
      <view class="suggest-label">卡片</view>
      <view
        wx:for="{{suggestions.cards}}"
        wx:key="id"
        class="suggest-card"
        data-id="{{item.id}}"
        catchtap="onSuggestionCardTap"
      >
        {{item.title}}
      </view>
    </view>
  </view>

  <view class="status-tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="value"
      class="status-tab {{status === item.value ? 'active' : ''}}"
      data-status="{{item.value}}"
      bindtap="onTabTap"
    >
      {{item.label}}
    </view>
  </view>

  <view class="summary-row">
    <text>共 {{total}} 张</text>
    <view wx:if="{{selectedTag}}" class="active-filter">
      <text>标签：#{{selectedTag}}</text>
      <view class="filter-clear" bindtap="onClearTagTap">×</view>
    </view>
  </view>

  <view class="cards-region">
    <scroll-view class="cards-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{!loading && cards.length === 0}}" class="empty">
        <view class="empty-title">{{loggedIn ? '暂无卡片' : '登录后查看卡片'}}</view>
        <view class="empty-text">{{loggedIn ? '点击底部加号新建一张卡片。' : '登录后会显示你的内容池。'}}</view>
      </view>

      <view class="card-list">
        <view wx:for="{{cards}}" wx:key="id" class="card-item">
          <view class="card-head">
            <view class="status {{item.status}}">
              <view class="status-dot"></view>
              <text>{{item.statusText}}</text>
            </view>
            <view class="delete-touch" catchtap="onDeleteTap" data-id="{{item.id}}">
              <view class="trash-icon">
                <view class="trash-lid"></view>
                <view class="trash-body"></view>
              </view>
            </view>
          </view>

          <view class="card-title">{{item.title}}</view>
          <view wx:if="{{item.summary}}" class="card-summary">{{item.summary}}</view>
          <view wx:elif="{{item.sourceText}}" class="card-summary">{{item.sourceText}}</view>

          <view class="card-time">更新于 {{item.updatedAtText}}</view>

          <view class="tag-row" wx:if="{{item.tags && item.tags.length}}">
            <text wx:for="{{item.tags}}" wx:key="*this" class="tag">#{{item}}</text>
          </view>

          <view class="card-actions">
            <view class="ghost-button" catchtap="onCardTap" data-id="{{item.id}}">查看</view>
            <view
              wx:if="{{item.status === 'todo'}}"
              class="gradient-button"
              catchtap="onOrganizeTap"
              data-id="{{item.id}}"
            >
              编辑
            </view>
            <view
              wx:elif="{{item.status === 'archived'}}"
              class="gradient-button"
              catchtap="onRestoreTap"
              data-id="{{item.id}}"
            >
              恢复整理
            </view>
            <view
              wx:else
              class="gradient-button"
              catchtap="onOrganizeTap"
              data-id="{{item.id}}"
            >
              编辑
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="scroll-fade scroll-fade-top"></view>
    <view class="scroll-fade scroll-fade-bottom"></view>
  </view>

  <bottom-nav active="pool"></bottom-nav>
</view>
