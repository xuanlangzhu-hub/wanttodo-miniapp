<view class="page">
  <view class="header">
    <view class="eyebrow">知识卡片</view>
    <view class="title">内容池</view>
  </view>

  <view class="tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="value"
      class="tab {{status === item.value ? 'active' : ''}}"
      data-status="{{item.value}}"
      bindtap="onTabTap"
    >
      {{item.label}}
    </view>
  </view>

  <view class="summary">共 {{total}} 张</view>

  <view wx:if="{{!loading && cards.length === 0}}" class="empty">
    <view class="empty-title">暂无卡片</view>
    <view class="empty-text">点击底部加号新建一张卡片。</view>
  </view>

  <view class="card-list">
    <view wx:for="{{cards}}" wx:key="id" class="card-item" data-id="{{item.id}}" bindtap="onCardTap">
      <view class="card-top">
        <view class="card-title">{{item.title}}</view>
        <view class="status {{item.status}}">{{item.statusText}}</view>
      </view>
      <view wx:if="{{item.summary}}" class="card-summary">{{item.summary}}</view>
      <view wx:elif="{{item.sourceText}}" class="card-summary">{{item.sourceText}}</view>
      <view class="tag-row" wx:if="{{item.tags && item.tags.length}}">
        <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="card-footer">
        <text>{{item.updatedAtText}}</text>
        <view class="card-actions">
          <button wx:if="{{item.status === 'todo'}}" class="text-button primary-link" catchtap="onOrganizeTap" data-id="{{item.id}}">去整理</button>
          <button wx:elif="{{item.status === 'archived'}}" class="text-button" catchtap="onRestoreTap" data-id="{{item.id}}">恢复整理</button>
          <button wx:else class="text-button" catchtap="onOrganizeTap" data-id="{{item.id}}">编辑</button>
          <button wx:if="{{item.status !== 'archived'}}" class="text-button" catchtap="onArchiveTap" data-id="{{item.id}}">归档</button>
          <button wx:if="{{item.status === 'archived'}}" class="text-button danger-link" catchtap="onDeleteTap" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </view>
  </view>

  <bottom-nav active="pool"></bottom-nav>
</view>
