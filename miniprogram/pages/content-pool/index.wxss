page {
  height: 100vh;
  background: radial-gradient(circle at 50% 0%, #20202c 0%, #0e0e12 48%, #09090c 100%);
  overflow: hidden;
}

.page {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  padding: 106rpx 32rpx 0;
}

.search-shell {
  align-items: center;
  background: rgba(28, 28, 35, 0.74);
  border: 1rpx solid rgba(131, 131, 156, 0.28);
  border-radius: 42rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 18rpx 42rpx rgba(0, 0, 0, 0.22);
  display: flex;
  height: 84rpx;
  margin-bottom: 28rpx;
  padding: 0 30rpx;
  position: relative;
  z-index: 70;
}

.search-icon {
  border: 4rpx solid #a2a2b5;
  border-radius: 50%;
  box-sizing: border-box;
  height: 32rpx;
  margin-right: 18rpx;
  position: relative;
  width: 32rpx;
}

.search-icon::after {
  background: #a2a2b5;
  border-radius: 999rpx;
  bottom: -8rpx;
  content: "";
  height: 4rpx;
  position: absolute;
  right: -10rpx;
  transform: rotate(45deg);
  width: 18rpx;
}

.search-input {
  color: #ffffff;
  flex: 1;
  font-size: 28rpx;
  height: 84rpx;
}

.suggest-panel {
  background: linear-gradient(145deg, rgba(35, 35, 48, 0.94), rgba(16, 16, 24, 0.9));
  border: 1rpx solid rgba(131, 131, 156, 0.24);
  border-radius: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 20rpx 48rpx rgba(0, 0, 0, 0.32);
  box-sizing: border-box;
  margin: -12rpx 0 22rpx;
  padding: 20rpx;
  position: relative;
  z-index: 70;
}

.suggest-row {
  margin-bottom: 18rpx;
}

.suggest-row:last-child {
  margin-bottom: 0;
}

.suggest-label {
  color: #83839c;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.suggest-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.suggest-chip,
.suggest-card {
  background: rgba(14, 14, 18, 0.22);
  border: 1rpx solid rgba(131, 131, 156, 0.22);
  border-radius: 999rpx;
  color: #c1c1cd;
  font-size: 24rpx;
  padding: 10rpx 16rpx;
}

.tag-suggest {
  border-color: rgba(146, 78, 255, 0.34);
  color: #c9a7ff;
}

.suggest-card {
  border-radius: 16rpx;
  box-sizing: border-box;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.status-tabs {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  position: relative;
  width: 100%;
  z-index: 70;
}

.status-tab {
  align-items: center;
  background: rgba(28, 28, 35, 0.72);
  border: 1rpx solid rgba(131, 131, 156, 0.18);
  border-radius: 20rpx;
  box-sizing: border-box;
  color: #83839c;
  display: flex;
  font-size: 28rpx;
  height: 74rpx;
  justify-content: center;
  min-width: 0;
  padding: 0;
}

.status-tab.active {
  background: linear-gradient(135deg, rgba(255, 121, 102, 0.24), rgba(146, 78, 255, 0.28));
  border-color: rgba(255, 121, 102, 0.86);
  box-shadow: 0 0 26rpx rgba(146, 78, 255, 0.18);
  color: #ff9a86;
}

.summary-row {
  align-items: center;
  color: #83839c;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin: 34rpx 4rpx 26rpx;
  position: relative;
  z-index: 70;
}

.active-filter {
  align-items: center;
  background: rgba(146, 78, 255, 0.16);
  border: 1rpx solid rgba(146, 78, 255, 0.34);
  border-radius: 999rpx;
  color: #c9a7ff;
  display: flex;
  font-size: 23rpx;
  max-width: 420rpx;
  min-width: 0;
  padding: 8rpx 10rpx 8rpx 18rpx;
}

.active-filter text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-clear {
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  flex-shrink: 0;
  font-size: 28rpx;
  height: 34rpx;
  justify-content: center;
  line-height: 1;
  margin-left: 10rpx;
  width: 34rpx;
}

.cards-region {
  background: #0b0d16;
  border: 1rpx solid rgba(131, 131, 156, 0.08);
  border-radius: 26rpx;
  box-sizing: border-box;
  flex: 1;
  height: 0;
  margin: 0 0 154rpx;
  min-height: 0;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.cards-scroll {
  box-sizing: border-box;
  height: 100%;
  padding: 0;
  position: relative;
  width: 100%;
}

.empty {
  align-items: center;
  background: linear-gradient(145deg, rgba(35, 35, 48, 0.9), rgba(20, 20, 29, 0.78));
  border: 1rpx solid rgba(131, 131, 156, 0.24);
  border-radius: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 24rpx 60rpx rgba(0, 0, 0, 0.26);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 70rpx 32rpx;
}

.empty-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-text {
  color: #a2a2b5;
  font-size: 25rpx;
  line-height: 1.45;
  margin-top: 12rpx;
  text-align: center;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 20rpx 0 92rpx;
}

.card-item {
  animation: cardRise 420ms ease both;
  background: linear-gradient(145deg, rgba(35, 35, 48, 0.92), rgba(16, 16, 24, 0.84));
  border: 1rpx solid rgba(131, 131, 156, 0.28);
  border-radius: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 26rpx 62rpx rgba(0, 0, 0, 0.28);
  box-sizing: border-box;
  min-height: 300rpx;
  overflow: hidden;
  padding: 28rpx;
  position: relative;
}

.card-item:nth-child(2) {
  animation-delay: 45ms;
}

.card-item:nth-child(3) {
  animation-delay: 90ms;
}

.card-item:nth-child(4) {
  animation-delay: 135ms;
}

.card-item:nth-child(5) {
  animation-delay: 180ms;
}

.card-item::before {
  background: radial-gradient(circle, rgba(255, 121, 102, 0.14), rgba(255, 121, 102, 0) 62%);
  content: "";
  height: 220rpx;
  left: -80rpx;
  position: absolute;
  top: -70rpx;
  width: 280rpx;
}

.card-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 2;
}

.delete-touch {
  align-items: center;
  display: flex;
  height: 58rpx;
  justify-content: center;
  width: 58rpx;
}

.trash-icon {
  color: #83839c;
  height: 34rpx;
  position: relative;
  width: 34rpx;
}

.trash-lid {
  background: currentColor;
  border-radius: 999rpx;
  height: 4rpx;
  left: 4rpx;
  position: absolute;
  top: 3rpx;
  width: 26rpx;
}

.trash-body {
  border: 4rpx solid currentColor;
  border-radius: 4rpx;
  box-sizing: border-box;
  height: 24rpx;
  left: 7rpx;
  position: absolute;
  top: 9rpx;
  width: 20rpx;
}

.status {
  align-items: center;
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.status-dot {
  border-radius: 50%;
  height: 12rpx;
  margin-right: 10rpx;
  width: 12rpx;
}

.status.todo {
  background: rgba(146, 78, 255, 0.18);
  color: #c9a7ff;
}

.status.todo .status-dot {
  background: #924eff;
}

.status.done {
  background: rgba(46, 235, 210, 0.14);
  color: #63f0df;
}

.status.done .status-dot {
  background: #46d5c4;
}

.status.archived {
  background: rgba(131, 131, 156, 0.16);
  color: #a2a2b5;
}

.status.archived .status-dot {
  background: #83839c;
}

.card-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.28;
  margin-top: 26rpx;
  padding-right: 0;
  position: relative;
  word-break: break-all;
  z-index: 1;
}

.card-summary {
  color: #a2a2b5;
  display: -webkit-box;
  font-size: 28rpx;
  line-height: 1.55;
  margin-top: 16rpx;
  overflow: hidden;
  position: relative;
  text-overflow: ellipsis;
  word-break: break-all;
  z-index: 1;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.card-time {
  color: #666680;
  font-size: 24rpx;
  margin-top: 22rpx;
  position: relative;
  z-index: 1;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 18rpx;
  position: relative;
  z-index: 1;
}

.tag {
  background: rgba(53, 53, 66, 0.74);
  border-radius: 999rpx;
  color: #a2a2b5;
  font-size: 22rpx;
  padding: 8rpx 14rpx;
}

.card-actions {
  display: grid;
  gap: 20rpx;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  margin-top: 26rpx;
  position: relative;
  width: 100%;
  z-index: 1;
}

.ghost-button,
.gradient-button {
  align-items: center;
  border-radius: 14rpx;
  box-sizing: border-box;
  display: flex;
  font-size: 28rpx;
  height: 66rpx;
  justify-content: center;
  margin: 0;
  min-width: 0;
  padding: 0;
  width: 100%;
}

.ghost-button {
  background: rgba(14, 14, 18, 0.12);
  border: 1rpx solid rgba(131, 131, 156, 0.28);
  color: #e0e0e6;
}

.gradient-button {
  background: linear-gradient(100deg, #ff7966 0%, #bf44d9 58%, #7838ff 100%);
  box-shadow: 0 12rpx 28rpx rgba(146, 78, 255, 0.22);
  color: #ffffff;
}

.scroll-fade {
  left: 0;
  pointer-events: none;
  position: absolute;
  right: 0;
  z-index: 20;
}

.scroll-fade-top {
  background: linear-gradient(180deg, #0b0d16 0%, rgba(11, 13, 22, 0.72) 34%, rgba(11, 13, 22, 0) 100%);
  height: 68rpx;
  top: 0;
}

.scroll-fade-bottom {
  background: linear-gradient(180deg, rgba(11, 13, 22, 0) 0%, rgba(11, 13, 22, 0.62) 58%, #0b0d16 100%);
  bottom: 0;
  height: 112rpx;
}

@keyframes cardRise {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
