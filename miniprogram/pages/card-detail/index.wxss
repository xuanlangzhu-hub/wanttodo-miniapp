page {
  min-height: 100vh;
  background: radial-gradient(circle at 50% 0%, #20202c 0%, #0e0e12 48%, #09090c 100%);
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 0 32rpx 190rpx;
}

.nav {
  align-items: center;
  box-sizing: content-box;
  display: flex;
  left: 0;
  padding-left: 26rpx;
  padding-right: 26rpx;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 40;
}

.nav::before {
  background: linear-gradient(180deg, rgba(14, 14, 18, 0.98), rgba(14, 14, 18, 0.76) 72%, rgba(14, 14, 18, 0));
  content: "";
  inset: 0;
  position: absolute;
}

.back-touch {
  align-items: center;
  display: flex;
  height: 72rpx;
  justify-content: center;
  position: relative;
  width: 72rpx;
  z-index: 1;
}

.back-icon {
  border-bottom: 4rpx solid #ffffff;
  border-left: 4rpx solid #ffffff;
  height: 22rpx;
  transform: rotate(45deg);
  width: 22rpx;
}

.nav-title {
  color: #ffffff;
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  margin-left: 8rpx;
  position: relative;
  z-index: 1;
}

.content-wrap {
  box-sizing: border-box;
}

.hero-card,
.reader-card,
.source-card {
  background: linear-gradient(145deg, rgba(35, 35, 48, 0.9), rgba(16, 16, 24, 0.78));
  border: 1rpx solid rgba(131, 131, 156, 0.24);
  border-radius: 30rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 26rpx 62rpx rgba(0, 0, 0, 0.28);
  box-sizing: border-box;
  overflow: hidden;
  padding: 30rpx;
  position: relative;
}

.hero-card::before {
  background: radial-gradient(circle, rgba(255, 121, 102, 0.2), rgba(255, 121, 102, 0) 64%);
  content: "";
  height: 260rpx;
  left: -100rpx;
  position: absolute;
  top: -100rpx;
  width: 320rpx;
}

.meta-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.status {
  align-items: center;
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.status-dot {
  border-radius: 50%;
  height: 12rpx;
  margin-right: 10rpx;
  width: 12rpx;
}

.status.todo {
  background: rgba(146, 78, 255, 0.18);
  color: #c9a7ff;
}

.status.todo .status-dot {
  background: #924eff;
}

.status.done {
  background: rgba(46, 235, 210, 0.14);
  color: #63f0df;
}

.status.done .status-dot {
  background: #46d5c4;
}

.status.archived {
  background: rgba(131, 131, 156, 0.16);
  color: #a2a2b5;
}

.status.archived .status-dot {
  background: #83839c;
}

.created-time {
  color: #83839c;
  font-size: 24rpx;
}

.title {
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.22;
  margin-top: 34rpx;
  position: relative;
  word-break: break-all;
  z-index: 1;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.tag {
  background: rgba(53, 53, 66, 0.74);
  border: 1rpx solid rgba(146, 78, 255, 0.18);
  border-radius: 999rpx;
  color: #c9a7ff;
  font-size: 23rpx;
  padding: 8rpx 16rpx;
}

.time-row {
  border-top: 1rpx solid rgba(131, 131, 156, 0.12);
  color: #83839c;
  display: flex;
  flex-direction: column;
  font-size: 23rpx;
  gap: 8rpx;
  line-height: 1.35;
  margin-top: 28rpx;
  padding-top: 20rpx;
  position: relative;
  z-index: 1;
}

.reader-card {
  margin-top: 26rpx;
  min-height: 420rpx;
}

.reader-card::after {
  background: linear-gradient(135deg, rgba(255, 121, 102, 0.12), rgba(146, 78, 255, 0.14));
  bottom: 0;
  content: "";
  height: 4rpx;
  left: 30rpx;
  position: absolute;
  right: 30rpx;
}

.reader-label,
.source-label {
  color: #83839c;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}

.summary-block {
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 600;
  line-height: 1.55;
  margin-bottom: 28rpx;
  word-break: break-all;
}

.body-text {
  color: #d9d9e3;
  font-size: 29rpx;
  line-height: 1.72;
  white-space: pre-wrap;
  word-break: break-all;
}

.empty-text {
  color: #83839c;
  font-size: 28rpx;
  line-height: 1.6;
}

.source-card {
  margin-top: 26rpx;
}

.source-link {
  color: #c9a7ff;
  font-size: 26rpx;
  line-height: 1.5;
  word-break: break-all;
}

.bottom-action {
  background: linear-gradient(180deg, rgba(9, 9, 12, 0), rgba(9, 9, 12, 0.82) 28%, rgba(9, 9, 12, 0.98));
  bottom: 0;
  box-sizing: border-box;
  left: 0;
  padding: 44rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 50;
}

.edit-button {
  align-items: center;
  background: linear-gradient(100deg, #ff7966 0%, #bf44d9 58%, #7838ff 100%);
  border-radius: 22rpx;
  box-shadow: 0 18rpx 44rpx rgba(146, 78, 255, 0.28), 0 10rpx 28rpx rgba(255, 121, 102, 0.18);
  color: #ffffff;
  display: flex;
  font-size: 30rpx;
  font-weight: 700;
  height: 92rpx;
  justify-content: center;
  line-height: 1;
  margin: 0;
}

.edit-button::after {
  border: 0;
}

.loading {
  align-items: center;
  color: #83839c;
  display: flex;
  font-size: 28rpx;
  justify-content: center;
  min-height: 100vh;
}
