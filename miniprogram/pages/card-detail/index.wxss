page {
  min-height: 100vh;
  background: #0e0e12;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx 72rpx;
}

.head,
.section,
.meta {
  background: #1c1c23;
  border: 1rpx solid #353542;
  border-radius: 8rpx;
  box-sizing: border-box;
  padding: 24rpx;
}

.head {
  margin-bottom: 20rpx;
}

.status {
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 22rpx;
  margin-bottom: 18rpx;
  padding: 6rpx 14rpx;
}

.status.todo {
  background: rgba(146, 78, 255, 0.18);
  color: #c9a7ff;
}

.status.done {
  background: rgba(46, 235, 210, 0.14);
  color: #63f0df;
}

.status.archived {
  background: #353542;
  color: #a2a2b5;
}

.title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.section,
.meta {
  margin-top: 18rpx;
}

.label {
  color: #83839c;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.content {
  color: #e0e0e6;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-all;
}

.pre {
  white-space: pre-wrap;
}

.link {
  color: #ad7bff;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  background: rgba(94, 0, 245, 0.22);
  border-radius: 6rpx;
  color: #c9a7ff;
  font-size: 22rpx;
  padding: 6rpx 10rpx;
}

.meta {
  color: #83839c;
  display: flex;
  flex-direction: column;
  font-size: 22rpx;
  gap: 8rpx;
}

.actions {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr 1fr;
  margin-top: 28rpx;
}

.primary,
.secondary,
.danger {
  align-items: center;
  border-radius: 8rpx;
  display: flex;
  font-size: 28rpx;
  height: 76rpx;
  justify-content: center;
  margin: 0;
}

.primary {
  background: linear-gradient(180deg, #ffa699 0%, #ff7966 100%);
  box-shadow: 0 12rpx 28rpx rgba(255, 121, 102, 0.28);
  color: #ffffff;
}

.secondary {
  background: #353542;
  color: #e0e0e6;
}

.danger {
  background: rgba(255, 121, 102, 0.12);
  color: #ff7966;
}
