<view class="page">
  <view class="nav" style="padding-top: {{navTop}}px; height: {{navHeight}}px;">
    <view class="back-touch" bindtap="onBackTap">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">查看卡片</view>
  </view>

  <view class="content-wrap" style="padding-top: {{contentTop}}px;" wx:if="{{card}}">
    <view class="hero-card">
      <view class="meta-row">
        <view class="status {{card.status}}">
          <view class="status-dot"></view>
          <text>{{statusText}}</text>
        </view>
        <text class="created-time">{{card.createdAtText}}</text>
      </view>

      <view class="title">{{card.title}}</view>

      <view class="tag-row" wx:if="{{card.tags && card.tags.length}}">
        <text wx:for="{{card.tags}}" wx:key="*this" class="tag">#{{item}}</text>
      </view>

      <view class="time-row" wx:if="{{card.updatedAtText}}">
        <text>更新 {{card.updatedAtText}}</text>
      </view>
    </view>

    <view
      class="reader-card {{copyHolding ? 'holding' : ''}}"
      bindtouchstart="onReaderTouchStart"
      bindtouchmove="onReaderTouchMove"
      bindtouchend="onReaderTouchEnd"
      bindtouchcancel="onReaderTouchCancel"
    >
      <view class="reader-label">卡片内容</view>

      <view wx:if="{{card.summary}}" class="summary-block">
        {{card.summary}}
      </view>

      <view wx:if="{{card.bodyText}}" class="body-text">
        {{card.bodyText}}
      </view>

      <view wx:if="{{!card.summary && !card.bodyText}}" class="empty-text">
        暂无内容
      </view>
    </view>

    <view class="source-card" wx:if="{{card.sourceUrl}}">
      <view class="source-label">来源</view>
      <view class="source-link">{{card.sourceUrl}}</view>
    </view>
  </view>

  <view class="loading" wx:elif="{{loading}}">
    读取中
  </view>

  <view class="loading" wx:else>
    暂无卡片
  </view>

  <view class="bottom-action" wx:if="{{card}}">
    <button class="edit-button" bindtap="onEditTap">编辑卡片</button>
  </view>
</view>
