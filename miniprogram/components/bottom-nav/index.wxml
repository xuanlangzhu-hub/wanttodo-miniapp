<view class="nav-shell">
  <image class="nav-bg" src="/images/nav/bg.png" mode="widthFix"></image>
  <view class="nav-items">
    <view class="nav-item" data-key="home" bindtap="onNavTap">
      <image wx:if="{{active === 'home'}}" class="nav-icon" src="/images/nav/home-active.png" mode="widthFix"></image>
      <image wx:else class="nav-icon" src="/images/nav/home.png" mode="widthFix"></image>
    </view>
    <view class="nav-item" data-key="pool" bindtap="onNavTap">
      <image wx:if="{{active === 'pool'}}" class="nav-icon" src="/images/nav/pool-active.png" mode="widthFix"></image>
      <image wx:else class="nav-icon" src="/images/nav/pool.png" mode="widthFix"></image>
    </view>
    <view class="nav-spacer"></view>
    <view class="nav-item" data-key="pending" bindtap="onNavTap">
      <image wx:if="{{active === 'pending'}}" class="nav-icon" src="/images/nav/pending-active.png" mode="widthFix"></image>
      <image wx:else class="nav-icon" src="/images/nav/pending.png" mode="widthFix"></image>
    </view>
    <view class="nav-item" data-key="me" bindtap="onNavTap">
      <image wx:if="{{active === 'me'}}" class="nav-icon" src="/images/nav/me-active.png" mode="widthFix"></image>
      <image wx:else class="nav-icon" src="/images/nav/me.png" mode="widthFix"></image>
    </view>
  </view>
  <image class="nav-cta" src="/images/nav/cta.png" mode="widthFix" bindtap="onCreateTap"></image>
</view>
