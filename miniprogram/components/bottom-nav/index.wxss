.nav-shell {
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  left: 50%;
  position: fixed;
  transform: translateX(-50%);
  width: 684rpx;
  z-index: 80;
}

.nav-panel {
  align-items: center;
  background: linear-gradient(180deg, rgba(38, 38, 52, 0.82), rgba(15, 15, 24, 0.9));
  border: 1rpx solid rgba(193, 193, 205, 0.2);
  border-radius: 42rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.11), inset 0 -10rpx 24rpx rgba(0, 0, 0, 0.24), 0 24rpx 62rpx rgba(0, 0, 0, 0.5), 0 0 40rpx rgba(146, 78, 255, 0.12);
  box-sizing: border-box;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  height: 116rpx;
  overflow: hidden;
  padding: 10rpx 18rpx 8rpx;
  position: relative;
}

.nav-panel::before {
  background: linear-gradient(90deg, rgba(255, 121, 102, 0.12), rgba(146, 78, 255, 0.14), rgba(255, 121, 102, 0.04));
  content: "";
  height: 1rpx;
  left: 34rpx;
  position: absolute;
  right: 34rpx;
  top: 1rpx;
}

.nav-panel::after {
  background: radial-gradient(circle at 50% 0%, rgba(146, 78, 255, 0.18), rgba(146, 78, 255, 0) 56%);
  content: "";
  height: 116rpx;
  left: 0;
  pointer-events: none;
  position: absolute;
  right: 0;
  top: 0;
}

.nav-item,
.nav-create {
  align-items: center;
  display: flex;
  flex-direction: column;
  height: 94rpx;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.nav-item {
  border-radius: 28rpx;
}

.nav-item.active {
  background: linear-gradient(180deg, rgba(255, 121, 102, 0.08), rgba(146, 78, 255, 0.1));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.07), 0 0 22rpx rgba(146, 78, 255, 0.12);
}

.nav-icon {
  color: #83839c;
  height: 36rpx;
  margin-bottom: 8rpx;
  position: relative;
  width: 36rpx;
}

.nav-label {
  color: #83839c;
  font-size: 22rpx;
  line-height: 1;
}

.nav-item.active .nav-icon {
  color: #d65bff;
}

.nav-item.active .nav-label {
  background: linear-gradient(100deg, #ff7966 0%, #d94dde 54%, #8a4cff 100%);
  color: #ff7966;
  font-weight: 700;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.home-roof {
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  height: 18rpx;
  left: 7rpx;
  position: absolute;
  top: 2rpx;
  transform: rotate(45deg);
  width: 18rpx;
}

.home-body {
  border: 4rpx solid currentColor;
  border-radius: 5rpx;
  border-top: 0;
  bottom: 2rpx;
  height: 18rpx;
  left: 6rpx;
  position: absolute;
  width: 20rpx;
}

.card-icon {
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.card-line {
  background: currentColor;
  border-radius: 999rpx;
  height: 3rpx;
  left: 8rpx;
  position: absolute;
  top: 10rpx;
  width: 14rpx;
}

.card-line.short {
  top: 20rpx;
  width: 10rpx;
}

.grid-icon {
  display: grid;
  gap: 6rpx;
  grid-template-columns: repeat(2, 1fr);
}

.grid-icon view {
  border: 4rpx solid currentColor;
  border-radius: 5rpx;
}

.user-head {
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
  height: 16rpx;
  left: 10rpx;
  position: absolute;
  top: 2rpx;
  width: 16rpx;
}

.user-body {
  border: 4rpx solid currentColor;
  border-radius: 16rpx 16rpx 4rpx 4rpx;
  box-sizing: border-box;
  height: 18rpx;
  left: 5rpx;
  position: absolute;
  top: 20rpx;
  width: 26rpx;
}

.create-button {
  align-items: center;
  background: linear-gradient(135deg, #ff7966 0%, #d94dde 54%, #7838ff 100%);
  border-radius: 50%;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.24), inset 0 -8rpx 18rpx rgba(72, 22, 120, 0.26), 0 0 34rpx rgba(146, 78, 255, 0.44), 0 0 26rpx rgba(255, 121, 102, 0.28), 0 14rpx 26rpx rgba(0, 0, 0, 0.34);
  color: #ffffff;
  display: flex;
  font-size: 48rpx;
  font-weight: 300;
  height: 62rpx;
  justify-content: center;
  line-height: 1;
  margin-bottom: 7rpx;
  position: relative;
  width: 62rpx;
}

.create-label {
  color: #a2a2b5;
}
